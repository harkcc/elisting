{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "emag_detail_product_input.schema.json",
  "title": "eMAG Detail Product Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_id",
    "brand",
    "language",
    "product_title",
    "product_type",
    "core_features",
    "specs",
    "compatibility",
    "package_contents"
  ],
  "properties": {
    "product_id": {
      "type": "string",
      "minLength": 1
    },
    "source_product_id": {
      "type": "string"
    },
    "brand": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "product_title": {
      "type": "string",
      "minLength": 1
    },
    "product_type": {
      "type": "string",
      "minLength": 1
    },
    "core_features": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "specs": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "value"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "compatibility": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "package_contents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slot",
          "url"
        ],
        "properties": {
          "slot": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
